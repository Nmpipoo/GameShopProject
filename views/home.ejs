<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>GameHub</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <!-- NAVBAR -->
    <div class="navbar">
        <div class="logo">GameHub</div>
        <div class="nav-links">
            <a href="#">Library</a>
            <a href="#">Wishlist</a>
            <a href="#">Support</a>
            <a href="#">Profile</a>
        </div>
    </div>

    <!-- SEARCH -->
    <div class="search-bar">
        <input type="text" placeholder="Search Game">
    </div>

    <!-- HERO -->
    <div class="hero-slider">
    <button class="hero-arrow left" onclick="prevSlide()">&#10094;</button>

    <div class="hero-wrapper" id="heroWrapper">
        <% games.forEach(function(game) { %>
    <div class="hero-slide">
        <div class="hero-left">
            <img src="<%= game.image %>" alt="<%= game.name %>">
        </div>

        <div class="hero-right">
            <h1><%= game.name %></h1>
            <div class="hero-price">$<%= game.price %></div>
            <button class="buy-btn">Buy Now</button>
        </div>
    </div>
<% }) %>
    </div>

    <button class="hero-arrow right" onclick="nextSlide()">&#10095;</button>
</div>

    <!-- RECOMMENDED -->
    <div class="section">
    <h2>Recommended Games</h2>

    <div class="carousel-container">
        <button class="carousel-arrow left">&#10094;</button>

        <div class="carousel-track">
            <% games.forEach(function(game) { %>
                <div class="game-card">
                    <div class="game-thumb">
                        <img src="<%= game.image %>" alt="<%= game.name %>" />
                    </div>
                    <div class="game-info">
                        <h4><%= game.name %></h4>
                        <div class="price">$<%= game.price %></div>
                    </div>
                </div>
            <% }) %>
        </div>

        <button class="carousel-arrow right">&#10095;</button>
    </div>
</div>

    <!-- NEW GAMES -->
    <div class="section">
    <h2>New Games</h2>

    <div class="carousel-container">
        <button class="carousel-arrow left" onclick="prevNew()">&#10094;</button>

        <div class="carousel-track" id="newTrack">
            <% games.forEach(function(game) { %>
                <div class="game-card">
                    <div class="game-thumb">
                        <img src="<%= game.image %>" alt="<%= game.name %>">
                    </div>
                    <div class="game-info">
                        <h4><%= game.name %></h4>
                        <div class="price">$<%= game.price %></div>
                    </div>
                </div>
            <% }) %>
        </div>

        <button class="carousel-arrow right" onclick="nextNew()">&#10095;</button>
    </div>
</div>

    <!-- TRENDING -->
    <div class="section">
    <h2>New Games</h2>

    <div class="carousel-container">
        <button class="carousel-arrow left" onclick="prevTrending()">&#10094;</button>

        <div class="carousel-track" id="trendingTrack">
            <% games.forEach(function(game) { %>
                <div class="game-card">
                    <div class="game-thumb">
                        <img src="<%= game.image %>" alt="<%= game.name %>">
                    </div>
                    <div class="game-info">
                        <h4><%= game.name %></h4>
                        <div class="price">$<%= game.price %></div>
                    </div>
                </div>
            <% }) %>
        </div>

        <button class="carousel-arrow right" onclick="nextTrending()">&#10095;</button>
    </div>
</div>

<script>
    const heroWrapper = document.getElementById("heroWrapper");
    const slides = document.querySelectorAll(".hero-slide");
    let index = 0;

    function updateSlider() {
        heroWrapper.style.transform = `translateX(-${index * 100}%)`;
    }

    function nextSlide() {
        index = (index + 1) % slides.length;
        updateSlider();
    }

    function prevSlide() {
        index = (index - 1 + slides.length) % slides.length;
        updateSlider();
    }
</script>

<script>
document.querySelectorAll(".carousel-container").forEach(container => {

    const track = container.querySelector(".carousel-track");
    const cards = container.querySelectorAll(".game-card");
    const prevBtn = container.querySelector(".carousel-arrow.left");
    const nextBtn = container.querySelector(".carousel-arrow.right");

    const visibleCards = 3;
    const totalCards = cards.length;

    let index = 0;

    function update() {
        const cardWidth = cards[0].offsetWidth + 25;
        track.style.transform = `translateX(-${index * cardWidth}px)`;
    }

    nextBtn.addEventListener("click", () => {
        if (index >= totalCards - visibleCards) {
            index = 0; // loop to start
        } else {
            index += visibleCards;
        }
        update();
    });

    prevBtn.addEventListener("click", () => {
        if (index <= 0) {
            index = totalCards - visibleCards; // loop to end
        } else {
            index -= visibleCards;
        }
        update();
    });

});
</script>

</body>
</html>